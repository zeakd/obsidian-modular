{
  "name": "obsidian-modular",
  "version": "0.1.0",
  "description": "Modular plugin for Obsidian — diagram ↔ vault md sync.",
  "main": "main.js",
  "type": "module",
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "build": "opk build",
    "dev": "opk dev",
    "smoke": "opk smoke",
    "verify": "opk build && opk smoke",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/",
    "reload": "opk reload",
    "attach": "opk attach"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "obsidian": "^1.7.2",
    "obsidian-plugin-kit": "link:../kit/packages/opk",
    "obsidian-sim": "link:../kit/packages/sim",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactflow": "^11.11.4"
  },
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
