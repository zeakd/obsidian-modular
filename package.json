{
  "name": "obsidian-modular",
  "version": "0.1.0",
  "description": "Modular plugin for Obsidian — diagram ↔ vault md sync.",
  "main": "main.js",
  "scripts": {
    "build": "bun run build.ts",
    "dev": "bun --watch build.ts -- --watch",
    "typecheck": "tsc --noEmit",
    "smoke": "bun run test/smoke.ts",
    "verify": "bun run build && bun run smoke"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "happy-dom": "^20.9.0",
    "obsidian": "^1.7.2",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactflow": "^11.11.4"
  }
}
