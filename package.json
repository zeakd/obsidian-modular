{
  "name": "obsidian-modular",
  "version": "0.5.0",
  "description": "Modular plugin for Obsidian — diagram ↔ vault md sync.",
  "main": "main.js",
  "type": "module",
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "build": "opk build",
    "dev": "opk dev",
    "smoke": "opk smoke",
    "verify": "opk build && opk smoke",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/",
    "reload": "opk reload",
    "attach": "opk attach"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.4.0",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "obsidian": "^1.12",
    "obsidian-plugin-kit": "link:../kit/packages/opk",
    "obsidian-sim": "link:../kit/packages/sim",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
